# Bizing API Environment Variables

# Kimi API Key
# Supports both subscription and metered API keys
# Get your API key from: https://platform.moonshot.cn/
KIMI_API_KEY=your_kimi_api_key_here

# Optional: Override base URL (for subscription vs metered API)
# Subscription API: https://api.moonshot.cn/v1 (default)
# Metered API: Same endpoint, different key type
# KIMI_BASE_URL=https://api.moonshot.cn/v1

# Optional: Override default model
# KIMI_MODEL=kimi-k2.5

# Server Configuration
PORT=6129

# Database URL (when you add database)
# DATABASE_URL=postgresql://user:password@localhost:5432/bizing
